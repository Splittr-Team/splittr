# Splittr - Production Environment Variables Configuration
# Copy this file to .env.prod and fill in the values.

# API Base URL for HTTP client
API_BASE_URL=https://api.prod.splittr.skycore.dev/

# Vercel deployment bypass key
VERCEL_BYPASS_KEY=your_prod_vercel_bypass_key

#Deeplink Base URL
DEEPLINK_BASE_URL=https://splittr.skycore.dev