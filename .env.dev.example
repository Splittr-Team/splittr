# Splittr - Development Environment Variables Configuration
# Copy this file to .env.dev and fill in the values.

# API Base URL for HTTP client
API_BASE_URL=https://api.dev.splittr.skycore.dev/

# Vercel deployment bypass key
VERCEL_BYPASS_KEY=your_dev_vercel_bypass_key

#Deeplink Base URL
DEEPLINK_BASE_URL=https://dev.splittr.skycore.dev